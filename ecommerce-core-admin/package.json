{
    "name": "general-ecommerce-admin",
    "version": "0.1.0",
    "private": true,
    "description": "General Ecommerce Platform Admin Dashboard",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint src",
        "check:mojibake": "node scripts/check-mojibake.mjs",
        "a11y:test": "playwright test tests/a11y",
        "test:e2e": "playwright test",
        "a11y:ci": "npm run check:mojibake && npm run typecheck && npm run lint && npm run a11y:test && npm run build",
        "test": "node --test",
        "format": "prettier --check .",
        "format:write": "prettier --write .",
        "guard:legacy-platform": "node scripts/guard-no-legacy-platform.mjs",
        "guard:legacy-theme-templates": "node scripts/guard-no-legacy-theme-templates.mjs"
    },
    "dependencies": {
        "@emotion/cache": "^11.14.0",
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@fontsource/cairo": "^5.2.6",
        "@fontsource/tajawal": "^5.2.7",
        "@mui/material": "^7.3.1",
        "@tabler/icons-react": "^3.41.1",
        "leaflet": "^1.9.4",
        "lottie-react": "^2.4.1",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-easy-crop": "^5.5.7",
        "react-leaflet": "^5.0.0",
        "recharts": "^2.15.4",
        "socket.io-client": "^4.8.3",
        "stylis": "^4.3.6",
        "stylis-plugin-rtl": "^2.1.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.19.0",
        "@axe-core/playwright": "^4.10.2",
        "@types/leaflet": "^1.9.20",
        "@types/react": "^19.1.2",
        "@types/react-dom": "^19.1.2",
        "@types/stylis": "^4.2.7",
        "@vitejs/plugin-react": "^4.4.1",
        "@playwright/test": "^1.56.1",
        "eslint": "^9.19.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^17.5.0",
        "prettier": "^3.5.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.59.0",
        "vite": "^6.1.0"
    },
    "engines": {
        "node": ">=20.11.0"
    }
}