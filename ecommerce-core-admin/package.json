{
    "name": "catalog-rfq-admin",
    "version": "1.0.0",
    "private": true,
    "description": "Catalog and quote request administration",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint src",
        "test": "npm run typecheck",
        "format": "prettier --check .",
        "format:write": "prettier --write .",
        "check": "npm run typecheck && npm run lint && npm run build"
    },
    "dependencies": {
        "react": "^19.1.0",
        "react-dom": "^19.1.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.19.0",
        "@types/react": "^19.1.2",
        "@types/react-dom": "^19.1.2",
        "@vitejs/plugin-react": "^4.4.1",
        "eslint": "^9.19.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^17.5.0",
        "prettier": "^3.5.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.59.0",
        "vite": "^6.1.0"
    },
    "engines": {
        "node": ">=20.11.0"
    }
}
