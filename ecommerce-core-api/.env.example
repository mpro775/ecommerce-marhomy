NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://ecommerce_core:password@localhost:5432/ecommerce_core_rfq
DATABASE_POOL_SIZE=10

JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30

APP_NAME=Catalog RFQ
APP_URL=http://localhost:5174
APP_TIMEZONE=Asia/Aden
QUOTE_REQUEST_PREFIX=RFQ
QUOTE_CART_TTL_DAYS=14
QUOTE_CART_RETENTION_DAYS=180
QUOTE_CART_MAINTENANCE_INTERVAL_MS=900000
QUOTE_CART_VISITOR_HOURLY_LIMIT=10
QUOTE_CART_ACTIVITY_HOURLY_LIMIT=100
QUOTE_MIN_FORM_FILL_MS=1500
QUOTE_NOTIFICATION_EMAILS=sales@example.com

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
HTTP_JSON_BODY_LIMIT=1mb

EMAIL_DELIVERY_MODE=log
EMAIL_FROM=no-reply@example.com
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
STORAGE_BUCKET=catalog-media
STORAGE_PUBLIC_URL=http://localhost:9000/catalog-media
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_FORCE_PATH_STYLE=true

SENTRY_DSN=
