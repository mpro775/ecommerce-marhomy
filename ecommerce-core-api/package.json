{
  "name": "catalog-rfq-api",
  "version": "1.0.0",
  "private": true,
  "description": "Product catalog and quote request backend API",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "clean:dist": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('tsconfig.build.tsbuildinfo',{force:true});fs.rmSync('tsconfig.tsbuildinfo',{force:true});\"",
    "worker:outbox": "tsx src/workers/outbox.worker.ts",
    "admin:create": "node scripts/create-admin.mjs",
    "check:mojibake": "node scripts/check-mojibake.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run clean:dist && tsc -p tsconfig.build.json",
    "lint": "eslint src",
    "test": "npm run check:mojibake && npm run build && node --test \"test/**/*.test.js\"",
    "test:validation": "npm run build && node --test test/validation-contracts.test.js",
    "test:e2e:smoke": "npm run build && node --test \"test/**/*.test.js\"",
    "migrate:up": "node ./scripts/migrate.mjs up",
    "migrate:down": "node ./scripts/migrate.mjs down",
    "migrate:fresh": "node ./scripts/migrate-fresh.mjs",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "sast": "npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.1",
    "@nestjs/core": "^11.0.11",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.4.0",
    "@sentry/nestjs": "^10.65.0",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "exceljs": "^4.4.0",
    "file-type": "^21.3.4",
    "helmet": "^8.0.0",
    "joi": "^18.2.3",
    "mp4box": "^2.3.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.11",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
