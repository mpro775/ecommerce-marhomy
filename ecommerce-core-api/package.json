{
  "name": "general-ecommerce-api",
  "version": "0.1.0",
  "private": true,
  "description": "General Ecommerce - Backend API",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "clean:dist": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('tsconfig.build.tsbuildinfo',{force:true});fs.rmSync('tsconfig.tsbuildinfo',{force:true});\"",
    "worker:outbox": "tsx src/workers/outbox.worker.ts",
    "worker:notifications": "tsx src/workers/notifications.worker.ts",
    "worker:abandoned-carts": "tsx src/workers/abandoned-carts.worker.ts",
    "check:mojibake": "node scripts/check-mojibake.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run clean:dist && tsc -p tsconfig.build.json",
    "lint": "eslint src",
    "test": "npm run check:mojibake && npm run build && node --test \"test/**/*.test.js\"",
    "test:validation": "npm run build && node --test test/validation-contracts.test.js",
    "test:e2e:smoke": "npm run build && node --test \"test/store-resolver-routing.test.js\" \"test/sprint10-analytics-governance.test.js\"",
    "openapi:generate": "tsc -p tsconfig.build.json && node dist/scripts/generate-openapi.js",
    "migrate:up": "node ./scripts/migrate.mjs up",
    "migrate:down": "node ./scripts/migrate.mjs down",
    "seed:run": "node ./scripts/seed.mjs",
    "queue:health": "node ./scripts/queue-health.mjs",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "sast": "npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.901.0",
    "@aws-sdk/s3-request-presigner": "^3.901.0",
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.1",
    "@nestjs/core": "^11.0.11",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/swagger": "^11.0.3",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.1.19",
    "@sentry/nestjs": "^10.39.0",
    "@sentry/node": "^10.39.0",
    "amqplib": "^0.10.5",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.0.0",
    "ioredis": "^5.5.0",
    "joi": "^17.13.3",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.3",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@nestjs/testing": "^11.1.14",
    "@types/amqplib": "^0.10.7",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.11",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
