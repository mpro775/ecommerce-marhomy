NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://user:strong-password@database:5432/catalog_rfq
DATABASE_POOL_SIZE=20
JWT_ACCESS_SECRET=replace-with-a-unique-random-production-secret
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30
APP_NAME=Catalog RFQ
APP_URL=https://catalog.example.com
APP_TIMEZONE=Asia/Aden
QUOTE_REQUEST_PREFIX=RFQ
QUOTE_CART_TTL_DAYS=14
QUOTE_MIN_FORM_FILL_MS=1500
QUOTE_NOTIFICATION_EMAILS=sales@example.com
ALLOWED_ORIGINS=https://catalog.example.com,https://admin.example.com
HTTP_JSON_BODY_LIMIT=1mb
EMAIL_DELIVERY_MODE=smtp
EMAIL_FROM=no-reply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
S3_ENDPOINT=https://objects.example.com
S3_REGION=us-east-1
STORAGE_BUCKET=catalog-media
STORAGE_PUBLIC_URL=https://cdn.example.com/catalog-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=false
SENTRY_DSN=
