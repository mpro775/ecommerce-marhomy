# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://general_ecommerce:general_ecommerce@localhost:5432/general_ecommerce_store

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=general-ecommerce.events
NOTIFICATIONS_MAIN_QUEUE=general-ecommerce.notifications
NOTIFICATIONS_DLQ_QUEUE=general-ecommerce.notifications.dlq
NOTIFICATIONS_RETRY_CREATED_QUEUE=general-ecommerce.notifications.retry.created
NOTIFICATIONS_RETRY_STATUS_QUEUE=general-ecommerce.notifications.retry.status
NOTIFICATIONS_RETRY_INVENTORY_QUEUE=general-ecommerce.notifications.retry.inventory
NOTIFICATIONS_MAX_RETRIES=3
NOTIFICATIONS_RETRY_DELAY_MS=5000

# Inventory
INVENTORY_RESERVATION_TTL_MINUTES=30

PLATFORM_ADMIN_SECRET=change-me-in-production
TOKEN_HASH_SECRET=change-me-token-hash-secret-32-chars-minimum

# JWT — Merchant
JWT_ACCESS_SECRET=change-me-jwt-secret
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30

# JWT — Customer
JWT_CUSTOMER_ACCESS_SECRET=change-me-customer-jwt-secret
JWT_CUSTOMER_ACCESS_EXPIRES_IN=15m
CUSTOMER_REFRESH_TOKEN_TTL_DAYS=30
CUSTOMER_PASSWORD_RESET_TTL_MINUTES=30

# S3 Storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=general-ecommerce-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/general-ecommerce-media
S3_PRESIGNED_PUT_TTL_SECONDS=900
S3_PRESIGNED_GET_TTL_SECONDS=3600

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001
CSRF_ENABLED=false
API_PUBLIC_BASE_URL=http://localhost:3000
# Deep link base URL for mobile app (used in recovery emails, restock alerts)
MOBILE_APP_DEEP_LINK_BASE_URL=myapp://
# Production:
# NODE_ENV=production
# CSRF_ENABLED=true
MERCHANT_ADMIN_BASE_URL=http://localhost:5173

# Sentry
SENTRY_DSN=
SENTRY_RELEASE=

# Observability
METRICS_PREFIX=general-ecommerce
CORS_CACHE_TTL_MS=300000
CORS_CACHE_REFRESH_INTERVAL_MS=60000

# Auth Brute-Force Protection
AUTH_MAX_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MS=900000
AUTH_WINDOW_MS=900000

# OTP
AUTH_OTP_SECRET=change-me-otp-secret
AUTH_OTP_TTL_MINUTES=5
AUTH_OTP_MAX_VERIFY_ATTEMPTS=3
AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
AUTH_OTP_MAX_RESEND_COUNT=5

# Email
EMAIL_DELIVERY_MODE=log
EMAIL_FROM=noreply@[EMAIL_ADDRESS]
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
RESEND_API_BASE_URL=https://api.resend.com
RESEND_API_KEY=

# Webhooks
WEBHOOK_SECRET=change-me-webhook-secret
BILLING_WEBHOOK_SECRET=change-me-billing-webhook-secret
